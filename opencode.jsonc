// MetalSim Studios — OpenCode configuration
// =============================================
// Dynamic batch simulation team for metallurgical processes, adapted for OpenCode.
// 4 directors (primary agents, switch with Tab) + 11 leads + 31 specialists (subagents).
//
// IMPORTANT — about edit/bash permissions below:
// This project ships with NO predefined source tree (no src/, data/, tests/,
// tools/). Every agent's "edit" permission is intentionally just {"*": "ask"}
// (or includes only real studio paths like docs/knowledge-base/**) until your
// actual project has a real architecture. Once software-architecture-director
// and you settle on a tech stack and layout (recorded as an ADR in
// design/architecture/), run /apply-permissions to update this file with the
// real domain-folder allow-rules — that's when each lead/specialist gets the
// broad edit access within their own domain folder you originally asked for.
//
// MODEL PROVIDER — OpenCode Go subscription
// All 46 agents run on OpenCode Go (https://opencode.ai/docs/go/), a single
// subscription ($5 first month, then $10/month) covering every model in this
// team's roster: GLM-5.2/5.1, Kimi K2.7 Code/K2.6, MiMo-V2.5/Pro, MiniMax
// M3/M2.7, Qwen3.7 Max/Plus, Qwen3.6 Plus, DeepSeek V4 Pro/Flash.
//
// SETUP REQUIRED before first use:
//   1. Sign in at https://opencode.ai/auth and subscribe to Go
//   2. Run /connect in the OpenCode TUI, select "OpenCode Go", paste your API key
//   3. Run /models to confirm the models below are available to your account
//
// Usage limits (dollar-based, shared across all agents since they're one
// subscription): $12 / 5 hours, $30 / week, $60 / month. Cheaper models
// (DeepSeek V4 Flash, MiMo-V2.5) allow far more requests than expensive ones
// (GLM-5.2, Qwen3.7 Max) — see https://opencode.ai/docs/go/ for the current
// per-model request estimates if you're tuning which agents use which tier.
//
// If you exceed Go's usage limits, OpenCode automatically falls back to free
// models (or to your Zen balance if "Use balance" is enabled) rather than
// blocking requests outright.
{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md",
    "docs/domain-standards.md",
    "docs/coding-standards.md"
  ],
  "model": "opencode-go/deepseek-v4-pro",
  "small_model": "opencode-go/deepseek-v4-flash",
  "share": "disabled",
  "permission": {
    "edit": {
      "docs/knowledge-base/**": "allow",
      "src/**": "allow"
    }
  },
  "provider": {
    "opencode-go": {
      "options": {}
    }
  },
  "agent": {
    "chief-simulation-director": {
      "description": "Global coordination, vision, phase gates. Entry point for project status, scope, and sprint planning.",
      "mode": "primary",
      "model": "opencode-go/deepseek-v4-pro",
      "prompt": "{file:./.opencode/agent/chief-simulation-director.md}",
      "permission": {
        "edit": {
          "docs/knowledge-base/**": "allow",
    "src/**": "allow",
          "*": "ask"
        },
        "bash": {
          "*": "ask",
          "git status": "allow",
          "git log*": "allow",
          "git diff*": "allow"
        },
        "task": {
          "*": "deny",
          "process-domain-director": "allow",
          "software-architecture-director": "allow",
          "validation-director": "allow"
        }
      }
    },
    "process-domain-director": {
      "description": "Owns metallurgical process science integrity: thermodynamics, kinetics, transport, process control. Use for process model questions and PSRD ownership.",
      "mode": "primary",
      "model": "opencode-go/deepseek-v4-pro",
      "prompt": "{file:./.opencode/agent/process-domain-director.md}",
      "permission": {
        "edit": {
          "docs/knowledge-base/**": "allow",
    "src/**": "allow",
          "*": "ask"
        },
        "bash": {
          "*": "ask",
          "git status": "allow",
          "git log*": "allow",
          "git diff*": "allow"
        },
        "task": {
          "*": "deny",
          "thermodynamics-lead": "allow",
          "reaction-kinetics-lead": "allow",
          "transport-phenomena-lead": "allow",
          "process-control-lead": "allow"
        }
      }
    },
    "software-architecture-director": {
      "description": "Owns software architecture: engine, solvers, data I/O, UI. Use for architecture decisions, interface design, and technical stack questions.",
      "mode": "primary",
      "model": "opencode-go/deepseek-v4-pro",
      "prompt": "{file:./.opencode/agent/software-architecture-director.md}",
      "permission": {
        "edit": {
          "docs/knowledge-base/**": "allow",
          "production/simplicity-debt.md": "allow",
          "production/tech-debt.md": "allow",
    "src/**": "allow",
          "*": "ask"
        },
        "bash": {
          "*": "ask",
          "git status": "allow",
          "git log*": "allow",
          "git diff*": "allow",
          "grep*": "allow"
        },
        "task": {
          "*": "deny",
          "core-engine-lead": "allow",
          "numerical-methods-lead": "allow",
          "data-io-lead": "allow",
          "ui-ux-lead": "allow"
        }
      }
    },
    "validation-director": {
      "description": "Owns V&V strategy, acceptance criteria, validation reports. Use for validation campaigns, test strategy, and release quality gates.",
      "mode": "primary",
      "model": "opencode-go/deepseek-v4-pro",
      "prompt": "{file:./.opencode/agent/validation-director.md}",
      "permission": {
        "edit": {
          "docs/knowledge-base/**": "allow",
          "docs/technical/validation-reports/**": "allow",
          "design/srd/validation-plan.md": "allow",
    "src/**": "allow",
          "*": "ask"
        },
        "bash": {
          "*": "ask",
          "git status": "allow",
          "git log*": "allow"
        },
        "task": {
          "*": "deny",
          "process-validation-lead": "allow",
          "verification-lead": "allow",
          "qa-lead": "allow"
        }
      }
    },
    "thermodynamics-lead": {
      "description": "Thermodynamic modeling: Gibbs energy, phase equilibria, activity models. Invoke for any thermodynamics task.",
